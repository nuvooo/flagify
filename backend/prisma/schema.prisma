generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  memberships    OrganizationMember[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  createdFlags   FeatureFlag[] @relation("CreatedFlags")
  updatedFlags   FeatureFlag[] @relation("UpdatedFlags")
  acceptedInvites OrganizationInvite[] @relation(name: "AcceptedInvites")

  @@map("users")
}

model Organization {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members      OrganizationMember[]
  projects     Project[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  environments Environment[]
  featureFlags FeatureFlag[]
  invites      OrganizationInvite[]
  segments     Segment[]
  experiments  Experiment[]

  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  userId         String           @db.ObjectId
  organizationId String           @db.ObjectId
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectType {
  SINGLE
  MULTI
}

model Project {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  key            String
  description    String?
  type           ProjectType @default(SINGLE)
  allowedOrigins String[]    @default([]) // CORS origins allowed for SDK access
  organizationId String      @db.ObjectId
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  environments Environment[]
  featureFlags FeatureFlag[]
  brands       Brand[]
  auditLogs    AuditLog[]
  segments     Segment[]
  experiments  Experiment[]

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("projects")
}

model Brand {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  key         String
  description String?
  projectId   String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project          Project           @relation(fields: [projectId], references: [id])
  flagEnvironments FlagEnvironment[]

  @@unique([projectId, key])
  @@index([projectId])
  @@map("brands")
}

model Environment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  key            String
  sortOrder      Int      @default(0)
  projectId      String   @db.ObjectId
  organizationId String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  project          Project           @relation(fields: [projectId], references: [id])
  organization     Organization      @relation(fields: [organizationId], references: [id])
  flagEnvironments FlagEnvironment[]

  @@unique([projectId, key])
  @@index([projectId])
  @@index([organizationId])
  @@map("environments")
}

model FeatureFlag {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  key            String
  description    String?
  flagType       FlagType @default(BOOLEAN)
  organizationId String   @db.ObjectId
  projectId      String   @db.ObjectId
  createdById    String   @db.ObjectId
  updatedById    String?  @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization     Organization      @relation(fields: [organizationId], references: [id])
  project          Project           @relation(fields: [projectId], references: [id])
  createdBy        User              @relation("CreatedFlags", fields: [createdById], references: [id])
  updatedBy        User?             @relation("UpdatedFlags", fields: [updatedById], references: [id])
  flagEnvironments FlagEnvironment[]
  experiments      Experiment[]      // A/B tests using this flag

  @@unique([projectId, key])
  @@index([organizationId])
  @@index([projectId])
  @@index([createdById])
  @@map("feature_flags")
}

enum FlagType {
  BOOLEAN
  STRING
  NUMBER
  JSON
}

model FlagEnvironment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  flagId        String   @db.ObjectId
  environmentId String   @db.ObjectId
  brandId       String?  @db.ObjectId
  enabled       Boolean  @default(false)
  defaultValue  String   @default("false")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  flag           FeatureFlag     @relation(fields: [flagId], references: [id])
  environment    Environment     @relation(fields: [environmentId], references: [id])
  brand          Brand?          @relation(fields: [brandId], references: [id])
  targetingRules TargetingRule[]

  @@unique([flagId, environmentId, brandId])
  @@index([flagId])
  @@index([environmentId])
  @@index([brandId])
  @@map("flag_environments")
}

model TargetingRule {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  flagEnvId  String       @db.ObjectId
  name       String?
  operator   RuleOperator @default(AND)
  serveValue String
  isDefault  Boolean      @default(false)
  priority   Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // Relations
  flagEnvironment FlagEnvironment @relation(fields: [flagEnvId], references: [id])
  conditions      RuleCondition[]
  segmentId       String?         @db.ObjectId // Optional: link to reusable segment
  segment         Segment?        @relation(fields: [segmentId], references: [id])

  @@index([flagEnvId])
  @@index([segmentId])
  @@map("targeting_rules")
}

enum RuleOperator {
  AND
  OR
}

model RuleCondition {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  ruleId    String            @db.ObjectId
  attribute String
  operator  ConditionOperator
  value     String
  createdAt DateTime          @default(now())

  // Relations
  rule TargetingRule @relation(fields: [ruleId], references: [id])

  @@index([ruleId])
  @@map("rule_conditions")
}

enum ConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  NOT_CONTAINS
  GREATER_THAN
  LESS_THAN
  IN
  NOT_IN
  STARTS_WITH
  ENDS_WITH
  MATCHES_REGEX
}

// ==================== SEGMENTS ====================

model Segment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  key            String
  description    String?
  organizationId String   @db.ObjectId
  projectId      String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization    Organization    @relation(fields: [organizationId], references: [id])
  project         Project         @relation(fields: [projectId], references: [id])
  conditions      SegmentCondition[]
  targetingRules  TargetingRule[] // Rules using this segment

  @@unique([projectId, key])
  @@index([organizationId])
  @@index([projectId])
  @@map("segments")
}

model SegmentCondition {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  segmentId String            @db.ObjectId
  attribute String
  operator  ConditionOperator
  value     String
  createdAt DateTime          @default(now())

  // Relations
  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@index([segmentId])
  @@map("segment_conditions")
}

// ==================== A/B TESTING (EXPERIMENTS) ====================

model Experiment {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  key            String
  description    String?
  hypothesis     String?          // Test hypothesis
  organizationId String           @db.ObjectId
  projectId      String           @db.ObjectId
  flagId         String           @db.ObjectId // The flag being tested
  environmentId  String           @db.ObjectId // Environment where test runs
  status         ExperimentStatus @default(DRAFT)
  startDate      DateTime?
  endDate        DateTime?
  trafficAllocation Int           @default(100) // % of traffic in experiment
  createdById    String           @db.ObjectId
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  organization Organization      @relation(fields: [organizationId], references: [id])
  project      Project           @relation(fields: [projectId], references: [id])
  flag         FeatureFlag       @relation(fields: [flagId], references: [id])
  variants     ExperimentVariant[]
  metrics      ExperimentMetric[]
  events       ExperimentEvent[]

  @@unique([projectId, key])
  @@index([organizationId])
  @@index([projectId])
  @@index([flagId])
  @@index([status])
  @@map("experiments")
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  ARCHIVED
}

model ExperimentVariant {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  experimentId  String   @db.ObjectId
  name          String   // e.g., "Control", "Variant A"
  key           String   // e.g., "control", "variant-a"
  description   String?
  value         String   // The flag value for this variant
  trafficPercent Int     @default(50) // 0-100
  isControl     Boolean  @default(false)
  createdAt     DateTime @default(now())

  // Relations
  experiment Experiment       @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  events     ExperimentEvent[]

  @@unique([experimentId, key])
  @@index([experimentId])
  @@map("experiment_variants")
}

model ExperimentMetric {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  experimentId String        @db.ObjectId
  name         String
  type         MetricType
  eventName    String        // Event to track (e.g., "purchase", "signup")
  targetValue  Float?        // Target conversion rate, revenue, etc.
  isPrimary    Boolean       @default(false) // Primary success metric
  createdAt    DateTime      @default(now())

  // Relations
  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@map("experiment_metrics")
}

enum MetricType {
  CONVERSION    // Binary: did convert or not
  COUNT         // Number of events
  SUM           // Sum of values (e.g., revenue)
  AVERAGE       // Average value
  UNIQUE_COUNT  // Unique users who performed action
}

model ExperimentEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  experimentId String  @db.ObjectId
  variantId   String   @db.ObjectId
  userId      String?  // Anonymous or identified user
  sessionId   String?  // For session-based tracking
  eventType   String   // "exposure" (saw variant) or metric event name
  value       Float?   // For SUM/AVERAGE metrics
  metadata    Json?    // Additional context
  createdAt   DateTime @default(now())

  // Relations
  experiment Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant    ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@index([variantId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("experiment_events")
}

// ==================== API KEYS & AUDIT ====================

model ApiKey {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  key           String     @unique
  type          ApiKeyType @default(SERVER)
  organizationId String    @db.ObjectId
  userId        String?    @db.ObjectId
  environmentId String?
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@map("api_keys")
}

enum ApiKeyType {
  SERVER
  CLIENT
  SDK
}

model AuditLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  action         String
  entityType     String
  entityId       String
  organizationId String   @db.ObjectId
  projectId      String?  @db.ObjectId
  userId         String?  @db.ObjectId
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model OrganizationInvite {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  email          String
  organizationId String           @db.ObjectId
  role           OrganizationRole @default(MEMBER)
  token          String           @unique
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  acceptedAt     DateTime?
  acceptedById   String?          @db.ObjectId

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  acceptedBy   User?        @relation(name: "AcceptedInvites", fields: [acceptedById], references: [id])

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("organization_invites")
}
